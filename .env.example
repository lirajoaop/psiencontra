# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/psiencontra?sslmode=disable

# AI Providers
GEMINI_API_KEY=your_gemini_api_key
GROQ_API_KEY=your_groq_api_key

# Server
PORT=8080
FRONTEND_URL=http://localhost:3000

# Environment: set to "development" for local HTTP dev. This unlocks an
# insecure JWT_SECRET placeholder and disables Secure cookies so browsers
# accept them over plain HTTP. NEVER set this in production.
APP_ENV=development

# Auth
# JWT_SECRET is required in production. In development (APP_ENV=development)
# an insecure placeholder is used if this is left empty.
JWT_SECRET=

# Google OAuth (optional — leave empty to disable Google login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/api/v1/auth/google/callback

# Cookie behavior. Defaults are derived from APP_ENV; only set these to
# override. COOKIE_SECURE=false is needed for local HTTP dev.
# COOKIE_SECURE=true
# COOKIE_DOMAIN=
